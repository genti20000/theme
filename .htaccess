Options -MultiViews
RewriteEngine On

# Canonical host: force non-www -> www
RewriteCond %{HTTP_HOST} ^londonkaraoke\.club$ [NC]
RewriteRule ^ https://www.londonkaraoke.club%{REQUEST_URI} [L,R=301,NE]

# Content hub migration: blog -> guides
RewriteRule ^blog/?$ /guides [L,R=301,NC]
RewriteRule ^blog/(.+)$ /guides/$1 [L,R=301,NC]

# Legacy URL redirects with SEO value
RewriteRule ^sitemap/?$ /sitemap.xml [L,R=301,NC]
RewriteRule ^terms-and-conditions/?$ /terms [L,R=301,NC]
RewriteRule ^birthday-karaoke/?$ /birthday-karaoke-soho [L,R=301,NC]
RewriteRule ^birthday-parties-private-karaoke-venue/?$ /birthday-karaoke-soho [L,R=301,NC]
RewriteRule ^hen-do-karaoke-party-soho-bar/?$ /hen-do-karaoke-soho [L,R=301,NC]
RewriteRule ^private-hen-do-karaoke-party/?$ /hen-do-karaoke-soho [L,R=301,NC]
RewriteRule ^jobs/?$ /careers [L,R=301,NC]
RewriteRule ^corporate-karaoke-soho/?$ /events [L,R=301,NC]
RewriteRule ^wp-content/uploads/2024/05/song_catalog_over-60K\.pdf$ /songs [L,R=301,NC]

# Flag admin for noindex headers
RewriteRule ^admin(/.*)?$ - [E=IS_ADMIN:1]

# Serve existing files/directories normally
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Only known SPA routes should resolve to index.html
RewriteRule ^(about|admin(/seo)?|birthday-karaoke-soho|booking-policy|careers|contact|drinks|events|faqs|food|gallery|guides(/[^/]+)?|hen-do-karaoke-soho|instagram|privacy|songs|terms)/?$ /index.html [L]
RewriteRule ^$ /index.html [L]

# Everything else is a real 404
ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=IS_ADMIN
</IfModule>
